{
  "manifest_version": 3,
  "name": "ТСН Мененджер (beta)",
  "version": "2.9.9",
  "description": "Автоматично ставить рекламу в паузах та запускає ефіри за вашим розкладом.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "windows",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://studio.youtube.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://studio.youtube.com/*"
      ],
      "js": [
        "src/config.js",
        "src/utils.js",
        "src/analyzer.js",
        "src/render.js",
        "src/injector.js",
        "src/ui.js",
        "src/init.js",
        "src/scheduler.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://studio.youtube.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "TSN manager"
  }
}