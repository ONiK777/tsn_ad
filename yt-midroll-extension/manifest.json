{
  "manifest_version": 3,
  "name": "ТСН АвтоРеклама",
  "version": "1.2.0",
  "description": "Автоматична розстановка рекламних пауз у YouTube Studio",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "https://studio.youtube.com/*",
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://studio.youtube.com/*"
      ],
      "js": [
        "src/config.js",
        "src/utils.js",
        "src/analyzer.js",
        "src/render.js",
        "src/injector.js",
        "src/ui.js",
        "src/init.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://studio.youtube.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TSN ad control"
  }
}